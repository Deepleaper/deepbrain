{
  "name": "deepbrain",
  "version": "0.1.0",
  "description": "Personal AI brain. Store, search, and grow your knowledge.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "deepbrain": "dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./search": {
      "import": "./dist/search/index.js",
      "types": "./dist/search/index.d.ts"
    },
    "./dream": {
      "import": "./dist/dream/index.js",
      "types": "./dist/dream/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run"
  },
  "keywords": [
    "ai",
    "brain",
    "knowledge",
    "memory",
    "personal",
    "second-brain",
    "embedding",
    "vector",
    "search",
    "agent",
    "deepbrain",
    "gbrain",
    "chinese",
    "multi-provider",
    "ollama",
    "deepseek",
    "gemini"
  ],
  "author": "Magicray1217",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Magicray1217/deepbrain"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.2.0",
    "agentkits": "^0.2.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
