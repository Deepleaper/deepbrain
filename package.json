{
  "name": "deepbrain",
  "version": "1.10.0",
  "description": "你的个人 AI 知识大脑 | Personal AI brain. Store, search, and grow your knowledge.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "deepbrain": "dist/cli.js",
    "deepbrain-mcp": "dist/mcp.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./search": {
      "import": "./dist/search/index.js",
      "types": "./dist/search/index.d.ts"
    },
    "./dream": {
      "import": "./dist/dream/index.js",
      "types": "./dist/dream/index.d.ts"
    },
    "./import": {
      "import": "./dist/import/index.js",
      "types": "./dist/import/index.d.ts"
    },
    "./tag-graph": {
      "import": "./dist/tag-graph/index.js",
      "types": "./dist/tag-graph/index.d.ts"
    },
    "./flashcards": {
      "import": "./dist/flashcards.js",
      "types": "./dist/flashcards.d.ts"
    },
    "./sdk": {
      "import": "./dist/sdk.js",
      "types": "./dist/sdk.d.ts"
    },
    "./backup": {
      "import": "./dist/backup.js",
      "types": "./dist/backup.d.ts"
    },
    "./collab": {
      "import": "./dist/collab.js",
      "types": "./dist/collab.d.ts"
    },
    "./templates": {
      "import": "./dist/templates.js",
      "types": "./dist/templates.d.ts"
    },
    "./digest-email": {
      "import": "./dist/digest-email.js",
      "types": "./dist/digest-email.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run"
  },
  "keywords": [
    "ai",
    "brain",
    "knowledge",
    "memory",
    "personal",
    "second-brain",
    "embedding",
    "vector",
    "search",
    "agent",
    "deepbrain",
    "gbrain",
    "chinese",
    "notion",
    "obsidian",
    "import",
    "export",
    "mcp",
    "claude",
    "cursor",
    "deepseek",
    "gemini",
    "evernote",
    "roam",
    "logseq",
    "bear",
    "flomo",
    "yuque",
    "feishu",
    "wechat",
    "knowledge-graph",
    "rag",
    "pglite",
    "pgvector",
    "web-ui",
    "clipper",
    "dream-cycle",
    "hybrid-search",
    "ollama",
    "local-first",
    "github-importer",
    "youtube-transcript",
    "rss-reader",
    "collaborative",
    "static-site"
  ],
  "homepage": "https://github.com/Magicray1217/deepbrain#readme",
  "author": "Magicray1217",
  "license": "LGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/Magicray1217/deepbrain"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.2.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "agentkits": "^0.2.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
